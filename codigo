import requests
from bs4 import BeautifulSoup

URL = "https://br.investing.com/news/latest-news"

def get_news():
    headers = {"User-Agent": "Mozilla/5.0"}

    try:
        response = requests.get(URL, headers=headers)
        response.raise_for_status()
    except Exception as e:
        print("Erro ao acessar o site:", e)
        return []

    soup = BeautifulSoup(response.text, "html.parser")

    noticias = []

    for item in soup.select("a[data-test='article-title-link']"):
        titulo = item.get_text(strip=True)
        if titulo:
            noticias.append(titulo)

    return noticias[:5]
🧠 3. ai_analysis.py
from openai import OpenAI
from config import OPENAI_API_KEY

client = OpenAI(api_key=OPENAI_API_KEY)

def analyze_news(texto):
    try:
        prompt = f"""
        Você é um analista de mercado financeiro.

        Analise a notícia abaixo e retorne:

        1. Resumo curto (1 frase)
        2. Sentimento: Positivo, Negativo ou Neutro

        Notícia:
        {texto}
        """

        response = client.chat.completions.create(
            model="gpt-4.1-mini",
            messages=[{"role": "user", "content": prompt}]
        )

        return response.choices[0].message.content.strip()

    except Exception as e:
        print("Erro na IA:", e)
        return "Erro ao analisar notícia."
